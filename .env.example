# Database
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/ptcg_battle_arena?retryWrites=true&w=majority

# Redis (Railway provides REDIS_URL automatically)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=generate_a_random_64_char_string_here
PTCG_BATTLE_ARENA_SHARED_SECRET=same_secret_as_in_ptcg_world

# ptcg.world integration
PTCG_WORLD_API_URL=https://ptcg.world

# Rails
RAILS_ENV=production
SECRET_KEY_BASE=generate_with_rails_secret

# Optional: Sidekiq Web auth
SIDEKIQ_WEB_USERNAME=admin
SIDEKIQ_WEB_PASSWORD=changeme
